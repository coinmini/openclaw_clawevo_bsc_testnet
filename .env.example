# BSC 部署配置
DEPLOYER_PRIVATE_KEY=0x...         # 部署者钱包私钥（需要 tBNB）
BSC_TESTNET_RPC_URL=https://bsc-testnet-dataseed.bnbchain.org
BSC_MAINNET_RPC_URL=https://bsc-dataseed.bnbchain.org
BSCSCAN_API_KEY=                   # BSCScan API Key（合约验证用）

# Faucet 运营钱包（给新玩家转 0.001 BNB gas）
OPERATOR_PK=0x...                  # 运营钱包私钥（需要 tBNB 余额）

# Treasury 钱包地址
DEV_WALLET=0x...                   # 开发团队钱包
FOUNDATION_WALLET=0x...            # 基金会钱包

# Binance Oracle VRF（运行 scripts/setup-vrf.ts 自动生成）
# BSC Testnet 默认值已内置，主网需手动配置
VRF_COORDINATOR=0xa2d23627bC0314f4Cbd08Ff54EcB89bb45685053  # BSC Testnet
VRF_KEY_HASH=0x617abc3f53ae11766071d04ada1c7b0fbd49833b9542e9e91da4d3191c70cc80
VRF_SUBSCRIPTION_ID=               # 运行 setup-vrf.ts 后填入
VRF_CONSUMER=                      # 部署 BinanceVRFConsumer 后填入
VRF_DEPOSIT_BNB=0.1                # 订阅充值额（0.0001 BNB/请求）
